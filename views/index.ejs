        <div class="modal fade" id="replaceReceiptConfirmModal" tabindex="-1" aria-labelledby="replaceReceiptConfirmModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header bg-warning">
                        <h5 class="modal-title" id="replaceReceiptConfirmModalLabel"><%= labels.replaceReceiptConfirmTitle %></h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="<%= labels.close %>"></button>
                    </div>
                    <div class="modal-body"><%= labels.replaceReceiptConfirm %></div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal"><%= labels.cancel %></button>
                        <button type="button" class="btn btn-warning" id="confirmReplaceReceiptButton"><%= labels.confirmReplaceReceipt %></button>
                    </div>
