                    }
                });

                safeRun(() => {
                    if (confirmReplaceReceiptButton) {
                        confirmReplaceReceiptButton.addEventListener("click", safeHandler(() => {
                            if (!pendingReplaceReceiptForm) {
                                return;
                            }

                            const formToSubmit = pendingReplaceReceiptForm;
                            const submitterToUse = pendingReplaceReceiptSubmitter;
                            pendingReplaceReceiptForm = null;
                            pendingReplaceReceiptSubmitter = null;

                            formToSubmit.dataset.replaceReceiptConfirmed = "1";
                            if (replaceReceiptConfirmModal) {
                                replaceReceiptConfirmModal.hide();
                            }

                            if (typeof formToSubmit.requestSubmit === "function") {
                                formToSubmit.requestSubmit(submitterToUse || undefined);
                                return;
                            }

                            formToSubmit.submit();
                        }));
                    }

                    if (replaceReceiptConfirmModalElement) {
                        replaceReceiptConfirmModalElement.addEventListener("hidden.bs.modal", safeHandler(() => {
                            pendingReplaceReceiptForm = null;
                            pendingReplaceReceiptSubmitter = null;
                        }));
                    }
                });

                safeRun(() => {
                    if (openSettingsModalButton && settingsModal) {
                        openSettingsModalButton.addEventListener("click", safeHandler(() => {
                            settingsModal.show();
                        }));
                    }
                });

                safeRun(() => {
                    if (openBackupModalButton && backupModal) {
                        openBackupModalButton.addEventListener("click", safeHandler(async () => {
                            backupStatus.innerHTML = '<div class="text-muted small"><span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Checking Google Drive status and backups...</div>';
                            backupResults.innerHTML = "";
                            backupModal.show();
                            await refreshBackupAuthState();
                            backupStatus.innerHTML = "";
                        }));
                    }
                });

                safeRun(() => {
                    const backupConnectButton = document.getElementById("backupConnectButton");
                    if (backupConnectButton) {
                        backupConnectButton.addEventListener("click", safeHandler((event) => {
                            event.preventDefault();
                            const authUrl = backupConnectButton.href || "/admin/backup/auth";
                            const authWindow = window.open(authUrl, "GoogleDriveAuth", "width=600,height=700");
                            if (authWindow) {
                                const checkClosed = setInterval(() => {
                                    if (authWindow.closed) {
                                        clearInterval(checkClosed);
                                        setTimeout(async () => {
                                            await refreshBackupAuthState();
                                        }, 500);
                                    }
                                }, 300);
                            }
                        }));
                    }
                });

                safeRun(() => {
                    window.addEventListener("message", safeHandler(async (event) => {
                        const eventType = String(event?.data?.type || "");
                        if (eventType !== "googleDriveAuthComplete" && eventType !== "googleDriveAuthFailed") {
                            return;
                        }

                        backupAuthErrorMessage = eventType === "googleDriveAuthFailed"
                            ? String(event?.data?.message || "Google Drive authorization failed.")
                            : "";
                        await refreshBackupAuthState();
                        if (backupAuthErrorMessage) {
                            renderBackupAuthErrorMessage();
                        } else {
                            backupStatus.innerHTML = "";
                        }
                    }));
                });

                safeRun(() => {
                    if (saveCredentialsButton) {
                        saveCredentialsButton.addEventListener("click", safeHandler(async () => {
                            try {
                                saveCredentialsButton.disabled = true;
                                credentialsSaveStatus.innerHTML = "";

                                const credentialsJson = credentialsJsonInput.value.trim();
                                if (!credentialsJson) {
                                    credentialsSaveStatus.innerHTML = '<div class="alert alert-danger py-1 px-2 small mb-0">Credentials JSON is required.</div>';
                                    saveCredentialsButton.disabled = false;
                                    return;
                                }

                                const response = await fetch("/admin/backup/credentials", {
                                    method: "POST",
                                    headers: {
                                        "Content-Type": "application/json"
                                    },
                                    body: JSON.stringify({
                                        credentialsJson
                                    }),
                                });

                                const data = await response.json();
                                if (data.success) {
                                    backupAuthErrorMessage = "";
                                    backupStatus.innerHTML = "";
                                    credentialsSaveStatus.innerHTML = '<div class="alert alert-success py-1 px-2 small mb-0">Credentials saved successfully!</div>';
                                    credentialsJsonInput.value = "";
                                    setTimeout(async () => {
                                        credentialsSaveStatus.innerHTML = "";
                                        saveCredentialsButton.disabled = false;
                                        await refreshBackupAuthState();
                                    }, 1500);
                                } else {
                                    credentialsSaveStatus.innerHTML = `<div class="alert alert-danger py-1 px-2 small mb-0">${data.error || "Failed to save credentials."}</div>`;
                                    saveCredentialsButton.disabled = false;
                                }
                            } catch {
                                credentialsSaveStatus.innerHTML = '<div class="alert alert-danger py-1 px-2 small mb-0">Error saving credentials. Please try again.</div>';
                                saveCredentialsButton.disabled = false;
                            }
                        }));
                    }
                });

                safeRun(() => {
                    if (backupDisconnectButton) {
                        backupDisconnectButton.addEventListener("click", safeHandler(async () => {
                            await fetch("/admin/backup/revoke", {
                                method: "POST"
                            });
                            backupStatus.innerHTML = "";
                            backupResults.innerHTML = "";
                            await refreshBackupAuthState();
                        }));
                    }

                    if (backupNowButton) {
                        backupNowButton.addEventListener("click", safeHandler(async () => {
                            let shouldHideBackupNowButton = false;
                            try {
                                const renderBackupProgress = (job) => {
                                    const safePercent = Math.max(0, Math.min(100, Number(job.percent || 0)));
                                    const message = String(job.message || "Working...");
                                    const stageLabel = String(job.stage || "running").replace(/_/g, " ");
                                    backupStatus.innerHTML = `
                                        <div class="mb-2"><strong>${stageLabel}</strong>: ${message}</div>
                                        <div class="progress" role="progressbar" aria-valuenow="${safePercent}" aria-valuemin="0" aria-valuemax="100">
                                            <div class="progress-bar progress-bar-striped progress-bar-animated" style="width: ${safePercent}%">${safePercent}%</div>
                                        </div>
                                    `;
                                };

                                const wait = (ms) => new Promise((resolve) => {
                                    setTimeout(resolve, ms);
                                });

                                backupStatus.innerHTML = '<div class="spinner-border spinner-border-sm me-2" role="status"><span class="visually-hidden">Loading...</span></div>Starting backup...';
                                backupResults.innerHTML = "";
                                backupNowButton.disabled = true;

                                const response = await fetch("/admin/backup/start", {
                                    method: "POST",
                                    headers: {
                                        "Content-Type": "application/json"
                                    },
                                });
                                const data = await response.json();

                                if (data.success && data.jobId) {
                                    let jobCompleted = false;

                                    while (!jobCompleted) {
                                        const progressResponse = await fetch(`/admin/backup/progress/${encodeURIComponent(data.jobId)}`);
                                        const progressData = await progressResponse.json();

                                        if (!progressData.success || !progressData.job) {
                                            backupStatus.innerHTML = '<div class="alert alert-danger mb-0"><strong>✗ Error:</strong> Could not read backup progress.</div>';
                                            break;
                                        }

                                        const job = progressData.job;
                                        renderBackupProgress(job);

                                        if (job.status === "completed") {
                                            backupStatus.innerHTML = `<div class="alert alert-success mb-0"><strong>✓ Success!</strong> Backup completed successfully.</div>`;
                                            shouldHideBackupNowButton = true;
                                            if (restoreFromDriveButton) {
                                                restoreFromDriveButton.classList.add("d-none");
                                            }
                                            if (job.result && job.result.files) {
                                                const filesList = job.result.files.map((f) => f.name).join(", ");
                                                const cleanupStatus = job.result.zipDeleted ?
                                                    "Local temporary zip deleted." :
                                                    "Local temporary zip could not be deleted.";
                                                backupResults.innerHTML = `<div class="text-muted small mt-1"><strong>Backed up:</strong> ${filesList}<br><strong>Cleanup:</strong> ${cleanupStatus}</div>`;
                                            }
                                            jobCompleted = true;
                                            break;
                                        }

                                        if (job.status === "failed") {
                                            backupStatus.innerHTML = `<div class="alert alert-danger mb-0"><strong>✗ Error:</strong> ${job.error || "Backup failed"}</div>`;
                                            jobCompleted = true;
                                            break;
                                        }

                                        await wait(700);
                                    }
                                } else if (data.error === "not_authorized") {
                                    await refreshBackupAuthState();
                                } else {
                                    backupStatus.innerHTML = `<div class="alert alert-danger mb-0"><strong>✗ Error:</strong> ${data.error || "Backup failed"}</div>`;
                                }
                            } catch (fetchError) {
                                backupStatus.innerHTML = `<div class="alert alert-danger mb-0"><strong>✗ Error:</strong> ${fetchError.message}</div>`;
