        <div class="modal fade" id="receiptPreviewModal" tabindex="-1" aria-labelledby="receiptPreviewModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="receiptPreviewModalLabel"><%= labels.receiptPreviewTitle %></h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="<%= labels.close %>"></button>
                    </div>
                    <div class="modal-body" id="receiptPreviewModalBody"></div>
                    <div class="modal-footer">
                        <a id="receiptPreviewOpenInNewTabButton" class="btn btn-outline-primary" href="#" target="_blank" rel="noopener noreferrer"><%= labels.openInNewTab %></a>
                        <a id="receiptPreviewDownloadButton" class="btn btn-primary" href="#" download><%= labels.downloadReceipt %></a>
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal"><%= labels.close %></button>
                    </div>
