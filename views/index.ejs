                                restoreConfirmSection.classList.add("d-none");
                                restoreConfirmButton.disabled = true;
                                backupStatus.innerHTML = '<div class="spinner-border spinner-border-sm me-2" role="status"><span class="visually-hidden">Loading...</span></div>Starting restore...';
                                backupResults.innerHTML = "";

                                const response = await fetch("/admin/restore/start", {
                                    method: "POST",
                                    headers: {
                                        "Content-Type": "application/json"
                                    },
                                    body: JSON.stringify({
                                        fileId: selectedRestoreFileId
                                    }),
                                });
                                const data = await response.json();

                                if (data.success && data.jobId) {
                                    let jobCompleted = false;
                                    while (!jobCompleted) {
                                        const progressResponse = await fetch(`/admin/backup/progress/${encodeURIComponent(data.jobId)}`);
                                        const progressData = await progressResponse.json();
                                        if (!progressData.success || !progressData.job) {
