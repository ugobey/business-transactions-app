                                        const job = progressData.job;
                                        renderRestoreProgress(job);
                                        if (job.status === "completed") {
                                            backupStatus.innerHTML = `<div class="alert alert-success mb-0"><strong>✓ Restore complete!</strong> Reloading page...</div>`;
                                            jobCompleted = true;
                                            await wait(1500);
                                            window.location.reload();
                                            break;
                                        }
                                        if (job.status === "failed") {
                                            backupStatus.innerHTML = `<div class="alert alert-danger mb-0"><strong>✗ Error:</strong> ${job.error || "Restore failed"}</div>`;
                                            restoreFromDriveButton.classList.remove("d-none");
                                            backupNowButton.classList.remove("d-none");
                                            jobCompleted = true;
                                            break;
                                        }
                                        await wait(700);
                                    }
                                } else if (data.error === "not_authorized") {
                                    await refreshBackupAuthState();
                                } else {
                                    backupStatus.innerHTML = `<div class="alert alert-danger mb-0"><strong>✗ Error:</strong> ${data.error || "Restore failed"}</div>`;
                                    restoreFromDriveButton.classList.remove("d-none");
                                    backupNowButton.classList.remove("d-none");
                                }
                            } catch (fetchError) {
                                backupStatus.innerHTML = `<div class="alert alert-danger mb-0"><strong>✗ Error:</strong> ${fetchError.message}</div>`;
                                restoreFromDriveButton.classList.remove("d-none");
                                backupNowButton.classList.remove("d-none");
                            } finally {
                                restoreConfirmButton.disabled = false;
                            }
                        }));
                    }
                });

                safeRun(() => {
                    if (shouldShowAnnualAlert && annualAlertModal) {
                        annualAlertModal.show();
                    }
                });

                safeRun(() => {
                    document.querySelectorAll("[data-open-receipt-preview]").forEach((element) => {
                        element.addEventListener("click", safeHandler((event) => {
                            event.preventDefault();
                            event.stopPropagation();
                            openReceiptPreviewModal(element.getAttribute("data-open-receipt-preview"));
                        }));
                    });

                    if (receiptPreviewModalElement) {
                        receiptPreviewModalElement.addEventListener("hidden.bs.modal", safeHandler(() => {
                            revokeActiveReceiptPreviewObjectUrl();
                            if (receiptPreviewModalBody) {
                                receiptPreviewModalBody.innerHTML = "";
                            }
                            if (receiptPreviewDownloadButton) {
                                receiptPreviewDownloadButton.href = "#";
                            }
                            if (receiptPreviewOpenInNewTabButton) {
                                receiptPreviewOpenInNewTabButton.href = "#";
                            }
                        }));
                    }
                });

                safeRun(() => {
                    const editRows = Array.from(document.querySelectorAll(".ledger-edit-row"));
                    const editForms = Array.from(document.querySelectorAll(".ledger-edit-form"));

                    function getEditableFields (form) {
                        try {
                            if (!form) {
                                return [];
                            }

                            return Array.from(form.querySelectorAll("input, select, textarea"))
                                .filter((field) => field.name && field.type !== "hidden");
                        } catch (error) {
                            throw withFunctionError("getEditableFields", error);
                        }
                    }

                    function buildFormSnapshot (form) {
                        try {
                            return getEditableFields(form)
                                .map((field) => {
                                    if (field.type === "checkbox") {
                                        return `${field.name}=${field.checked ? "1" : "0"}`;
                                    }

                                    return `${field.name}=${field.value}`;
                                })
                                .join("&");
                        } catch (error) {
                            throw withFunctionError("buildFormSnapshot", error);
                        }
                    }

                    function updateUpdateButtonVisibility (form) {
                        try {
                            if (!form) {
                                return;
                            }

                            const updateButton = form.querySelector("[data-update-button]");
                            if (!updateButton) {
                                return;
                            }

                            const initialSnapshot = form.dataset.initialSnapshot || "";
                            const currentSnapshot = buildFormSnapshot(form);
                            const hasChanges = currentSnapshot !== initialSnapshot;
                            updateButton.classList.toggle("d-none", !hasChanges);
                        } catch (error) {
                            throw withFunctionError("updateUpdateButtonVisibility", error);
                        }
                    }

                    editForms.forEach((form) => {
                        try {
                            initializeCustomerAndPaymentFields(form);
                            form.dataset.initialSnapshot = buildFormSnapshot(form);
                            getEditableFields(form).forEach((field) => {
                                field.addEventListener("input", safeHandler(() => {
                                    updateUpdateButtonVisibility(form);
                                }));
                                field.addEventListener("change", safeHandler(() => {
                                    updateUpdateButtonVisibility(form);
                                }));
                            });
                            updateUpdateButtonVisibility(form);
                        } catch (error) {
                            throw withFunctionError("initializeEditFormState", error);
                        }
                    });

                    function closeAllEditors () {
                        try {
                            editRows.forEach((row) => {
                                row.hidden = true;
                            });
                        } catch (error) {
                            throw withFunctionError("closeAllEditors", error);
                        }
                    }

                    function openEditor (editorId) {
                        try {
                            const target = document.getElementById(editorId);
                            if (!target) {
                                return;
                            }

                            if (!target.hidden) {
                                target.hidden = true;
                                return;
                            }

                            closeAllEditors();
                            target.hidden = false;
                            const form = target.querySelector(".ledger-edit-form");
                            updateUpdateButtonVisibility(form);
                            const firstInput = target.querySelector("input");
                            if (firstInput) {
                                firstInput.focus();
                            }
                        } catch (error) {
                            throw withFunctionError("openEditor", error);
                        }
                    }

                    document.querySelectorAll("[data-open-editor]").forEach((element) => {
                        element.addEventListener("click", safeHandler((event) => {
                            const clickedInteractiveElement = event.target instanceof Element ?
                                event.target.closest("button, a, input, select, textarea, form, label") :
                                null;
                            if (clickedInteractiveElement) {
                                return;
                            }

                            const editorId = element.getAttribute("data-open-editor");
                            openEditor(editorId);
                        }));
                    });

                    document.querySelectorAll("[data-close-editor]").forEach((element) => {
                        element.addEventListener("click", safeHandler(() => {
                            const editorId = element.getAttribute("data-close-editor");
                            const target = document.getElementById(editorId);
                            if (target) {
                                target.hidden = true;
                            }
                        }));
                    });
                });

                safeRun(() => {
                    const dateInputs = Array.from(document.querySelectorAll('input[type="date"]'));
                    dateInputs.forEach((dateInput) => {
                        try {
                            dateInput.addEventListener("focus", safeHandler(() => {
                                try {
                                    if (dateInput.showPicker) {
                                        dateInput.showPicker();
                                    }
                                } catch (error) {
                                    console.error(error);
                                }
                            }));
                        } catch (error) {
                            throw withFunctionError("initializeDatePickerAutoOpen", error);
                        }
                    });
                });

                safeRun(() => {
                    const newTransactionForm = document.querySelector('form[action="/transactions"]');
                    if (!newTransactionForm) {
                        return;
                    }

                    const newReceiptInput = newTransactionForm.querySelector('input[name="receiptNumber"]');
                    const newAttachmentInput = newTransactionForm.querySelector('input[name="attachment_upload"]');
                    const newPaymentMethod = newTransactionForm.querySelector('[name="payment_method"]');
                    const newPaymentReference = newTransactionForm.querySelector('[name="payment_reference"]');
                    initializeCustomerAndPaymentFields(newTransactionForm);

                    if (newAttachmentInput) {
                        newAttachmentInput.addEventListener("change", safeHandler(() => {
                            const selectedFile = newAttachmentInput.files && newAttachmentInput.files[0] ? newAttachmentInput.files[0] : null;
                            if (selectedFile && !isAllowedAttachmentFileType(selectedFile)) {
                                newAttachmentInput.value = "";
                                newAttachmentInput.setCustomValidity(invalidAttachmentTypeMessage);
                                updateReceiptFeedback(newAttachmentInput, invalidAttachmentTypeMessage);
                                showErrorModal(`${CLIENT_ERROR_PREFIX} ${invalidAttachmentTypeMessage}`);
                            } else {
                                newAttachmentInput.setCustomValidity("");
                                updateReceiptFeedback(newAttachmentInput, requiredFieldMessage);
                            }
                        }));
                    }

                    if (newReceiptInput) {
                        newReceiptInput.addEventListener("input", safeHandler(() => {
                            const duplicate = isDuplicateReceipt(newReceiptInput.value);
                            if (duplicate) {
                                newReceiptInput.setCustomValidity(duplicateReceiptMessage);
                                updateReceiptFeedback(newReceiptInput, duplicateReceiptMessage);
                            } else {
                                newReceiptInput.setCustomValidity("");
                                updateReceiptFeedback(newReceiptInput, requiredFieldMessage);
                            }
                        }));
                    }

                    newTransactionForm.addEventListener("submit", safeHandler((event) => {
                        try {
                            const paidByField = newTransactionForm.querySelector('[name="paidBy"]');
                            if (paidByField) {
                                paidByField.value = normalizePaidByAutocompleteSelection(paidByField.value);
                            }

                            if (newReceiptInput) {
                                const duplicate = isDuplicateReceipt(newReceiptInput.value);
                                if (duplicate) {
                                    newReceiptInput.setCustomValidity(duplicateReceiptMessage);
                                    updateReceiptFeedback(newReceiptInput, duplicateReceiptMessage);
                                } else {
                                    newReceiptInput.setCustomValidity("");
                                    updateReceiptFeedback(newReceiptInput, requiredFieldMessage);
                                }
                            }

                            if (newPaymentMethod && newPaymentReference) {
                                const newStatusInput = newTransactionForm.querySelector('[name="status"]');
                                const currentStatus = newStatusInput ? newStatusInput.value : "";
                                if (shouldRequirePaymentReference(newPaymentMethod.value, currentStatus) && !String(newPaymentReference.value || "").trim()) {
                                    newPaymentReference.setCustomValidity(paymentReferenceRequiredMessage);
                                } else {
                                    newPaymentReference.setCustomValidity("");
                                }
                            }

                            if (newAttachmentInput) {
                                const selectedFile = newAttachmentInput.files && newAttachmentInput.files[0] ? newAttachmentInput.files[0] : null;
                                if (selectedFile && !isAllowedAttachmentFileType(selectedFile)) {
                                    newAttachmentInput.setCustomValidity(invalidAttachmentTypeMessage);
                                    updateReceiptFeedback(newAttachmentInput, invalidAttachmentTypeMessage);
                                    showErrorModal(`${CLIENT_ERROR_PREFIX} ${invalidAttachmentTypeMessage}`);
                                } else {
                                    newAttachmentInput.setCustomValidity("");
                                    updateReceiptFeedback(newAttachmentInput, requiredFieldMessage);
                                }
                            }

                            if (!newTransactionForm.checkValidity()) {
                                event.preventDefault();
                                event.stopPropagation();
                                newTransactionForm.classList.add("was-validated");
                            } else {
                                newTransactionForm.classList.remove("was-validated");
                            }
                        } catch (error) {
                            throw withFunctionError("newTransactionFormSubmit", error);
                        }
                    }));
                });

                safeRun(() => {
                    const editForms = Array.from(document.querySelectorAll(".ledger-edit-form"));
                    editForms.forEach((form) => {
                        try {
                            const receiptInput = form.querySelector('input[name="receiptNumber"]');
                            const paymentMethodInput = form.querySelector('[name="payment_method"]');
                            const paymentReferenceInput = form.querySelector('[name="payment_reference"]');
                            const attachmentUploadInput = form.querySelector('[name="attachment_upload"]');
                            const transactionId = form.getAttribute("data-transaction-id") || "";
                            const originalReceipt = form.getAttribute("data-original-receipt") || "";
                            initializeCustomerAndPaymentFields(form);

                            if (attachmentUploadInput) {
                                attachmentUploadInput.addEventListener("change", safeHandler(() => {
                                    const selectedFile = attachmentUploadInput.files && attachmentUploadInput.files[0] ? attachmentUploadInput.files[0] : null;
                                    if (selectedFile && !isAllowedAttachmentFileType(selectedFile)) {
                                        attachmentUploadInput.value = "";
                                        attachmentUploadInput.setCustomValidity(invalidAttachmentTypeMessage);
                                        updateReceiptFeedback(attachmentUploadInput, invalidAttachmentTypeMessage);
                                        showErrorModal(`${CLIENT_ERROR_PREFIX} ${invalidAttachmentTypeMessage}`);
                                    } else {
                                        attachmentUploadInput.setCustomValidity("");
                                        updateReceiptFeedback(attachmentUploadInput, requiredFieldMessage);
                                    }
                                }));
                            }

                            if (receiptInput) {
                                receiptInput.addEventListener("input", safeHandler(() => {
                                    const duplicate = isDuplicateReceipt(receiptInput.value, transactionId, originalReceipt);
                                    if (duplicate) {
                                        receiptInput.setCustomValidity(duplicateReceiptMessage);
                                        updateReceiptFeedback(receiptInput, duplicateReceiptMessage);
                                    } else {
                                        receiptInput.setCustomValidity("");
                                        updateReceiptFeedback(receiptInput, requiredFieldMessage);
                                    }
                                }));
                            }

                            form.addEventListener("submit", safeHandler((event) => {
                                try {
                                    const submitter = event.submitter;
                                    const targetAction = String(submitter?.getAttribute("formaction") || form.getAttribute("action") || "");
                                    const isUpdateAction = targetAction.includes("/update");
                                    if (isUpdateAction) {
                                        const existingAttachmentPathInput = form.querySelector('[name="existing_attachment_path"]');
                                        const hasExistingAttachment = Boolean(String(existingAttachmentPathInput?.value || "").trim());
                                        const hasNewAttachment = Boolean(attachmentUploadInput?.files && attachmentUploadInput.files.length > 0);
                                        const hasReplaceReceiptConfirmation = form.dataset.replaceReceiptConfirmed === "1";

                                        if (hasExistingAttachment && hasNewAttachment && !hasReplaceReceiptConfirmation) {
                                            event.preventDefault();
                                            event.stopPropagation();
                                            pendingReplaceReceiptForm = form;
                                            pendingReplaceReceiptSubmitter = submitter || null;
                                            if (replaceReceiptConfirmModal) {
                                                replaceReceiptConfirmModal.show();
                                            } else {
                                                showErrorModal(`${CLIENT_ERROR_PREFIX} ${replaceReceiptConfirmMessage}`);
                                            }
                                            return;
                                        }

                                        delete form.dataset.replaceReceiptConfirmed;
                                    }

                                    if (attachmentUploadInput) {
                                        const selectedFile = attachmentUploadInput.files && attachmentUploadInput.files[0] ? attachmentUploadInput.files[0] : null;
                                        if (selectedFile && !isAllowedAttachmentFileType(selectedFile)) {
                                            attachmentUploadInput.setCustomValidity(invalidAttachmentTypeMessage);
                                            updateReceiptFeedback(attachmentUploadInput, invalidAttachmentTypeMessage);
                                            showErrorModal(`${CLIENT_ERROR_PREFIX} ${invalidAttachmentTypeMessage}`);
                                        } else {
                                            attachmentUploadInput.setCustomValidity("");
                                            updateReceiptFeedback(attachmentUploadInput, requiredFieldMessage);
                                        }
                                    }

                                    const paidByField = form.querySelector('[name="paidBy"]');
                                    if (paidByField) {
                                        paidByField.value = normalizePaidByAutocompleteSelection(paidByField.value);
                                    }

                                    if (receiptInput) {
                                        const duplicate = isDuplicateReceipt(receiptInput.value, transactionId, originalReceipt);
                                        if (duplicate) {
                                            receiptInput.setCustomValidity(duplicateReceiptMessage);
                                            updateReceiptFeedback(receiptInput, duplicateReceiptMessage);
                                        } else {
                                            receiptInput.setCustomValidity("");
                                            updateReceiptFeedback(receiptInput, requiredFieldMessage);
                                        }
                                    }

                                    if (paymentMethodInput && paymentReferenceInput) {
                                        const statusInput = form.querySelector('[name="status"]');
                                        const currentStatus = statusInput ? statusInput.value : "";
                                        if (shouldRequirePaymentReference(paymentMethodInput.value, currentStatus) && !String(paymentReferenceInput.value || "").trim()) {
                                            paymentReferenceInput.setCustomValidity(paymentReferenceRequiredMessage);
                                        } else {
                                            paymentReferenceInput.setCustomValidity("");
                                        }
                                    }

                                    if (!form.checkValidity()) {
                                        event.preventDefault();
                                        event.stopPropagation();
                                        form.classList.add("was-validated");
                                    } else {
                                        form.classList.remove("was-validated");
                                    }
                                } catch (error) {
                                    throw withFunctionError("editFormSubmit", error);
                                }
                            }));
                        } catch (error) {
                            throw withFunctionError("initializeEditFormValidation", error);
                        }
                    });
                });
            })();

        </script>
    </body>

</html>
