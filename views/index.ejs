                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="modal fade" id="backupModal" tabindex="-1" aria-labelledby="backupModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="backupModalLabel"><%= labels.backupRestore || 'Backup / Restore' %> — Google Drive</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="<%= labels.close %>"></button>
                    </div>
                    <div class="modal-body">
                        <div id="backupCredentialsSection" class="d-none">
                            <p class="mb-3 text-muted small">Your Google credentials file is missing or invalid. Paste your <strong>credentials.json</strong> content below:</p>
                            <textarea id="credentialsJsonInput" class="form-control mb-2" rows="8" placeholder="Paste the entire contents of your credentials.json file here..."></textarea>
                            <button type="button" class="btn btn-sm btn-primary w-100" id="saveCredentialsButton">Save Credentials</button>
                            <div id="credentialsSaveStatus" class="mt-2"></div>
                        </div>
                        <div id="backupAuthSection" class="d-none">
                            <p class="mb-3 text-muted small">Connect your Google account to back up transactions, audit trail, and receipts to your personal Google Drive.</p>
                            <a href="/admin/backup/auth" target="_blank" class="btn btn-outline-primary w-100" id="backupConnectButton">Connect Google Drive</a>
                            <p class="mt-2 text-muted small text-center">A new tab will open for authorization.</p>
                        </div>
                        <div id="backupConnectedSection" class="d-none">
                            <div class="alert alert-success py-2 mb-3">✓ Google Drive connected</div>
                        </div>
                        <div id="restoreInfoSection" class="d-none mb-3">
                            <div class="small fw-semibold mb-2">Select a backup to restore:</div>
                            <div id="restoreBackupList" class="vstack gap-1"></div>
                            <button type="button" class="btn btn-sm btn-danger mt-2 d-none" id="restoreSelectedButton"><%= labels.restoreFromDrive || 'Restore from Drive' %></button>
                        </div>
                        <div id="restoreConfirmSection" class="d-none alert alert-warning">
                            <p class="mb-1 small fw-semibold">Restore from: <span id="restoreSelectedName" class="fw-normal"></span></p>
                            <p class="mb-2 small"><%= labels.restoreConfirmBody || 'This will replace all current data with data from the latest backup. This cannot be undone.' %></p>
                            <button type="button" class="btn btn-sm btn-danger" id="restoreConfirmButton"><%= labels.restoreConfirmButton || 'Yes, Restore' %></button>
                            <button type="button" class="btn btn-sm btn-outline-secondary ms-2" id="restoreCancelButton"><%= labels.cancel %></button>
                        </div>
                        <div id="backupStatus" class="mb-2"></div>
                        <div id="backupResults"></div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-sm btn-link text-danger me-auto d-none" id="backupDisconnectButton">Disconnect</button>
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal"><%= labels.close %></button>
                        <button type="button" class="btn btn-outline-primary d-none" id="restoreFromDriveButton"><%= labels.restoreFromDrive || 'Restore from Drive' %></button>
                        <button type="button" class="btn btn-primary d-none" id="backupNowButton">Backup Now</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="modal fade" id="annualAlertModal" tabindex="-1" aria-labelledby="annualAlertModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header <%= annualAlertExceeded ? 'bg-danger text-white' : 'bg-warning text-dark' %>">
                        <h5 class="modal-title" id="annualAlertModalLabel"><%= labels.annualAlertTitle %></h5>
                        <button type="button" class="btn-close <%= annualAlertExceeded ? 'btn-close-white' : '' %>" data-bs-dismiss="modal" aria-label="<%= labels.close %>"></button>
                    </div>
                    <div class="modal-body">
                        <p class="mb-0"><%= annualAlertMessage %></p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal"><%= labels.close %></button>
                    </div>
                </div>
            </div>
        </div>

        <form id="deleteTransactionForm" method="POST" class="d-none">
            <input type="hidden" name="page" value="<%= currentPage %>" />
            <input type="hidden" name="fReceiptNumber" value="<%= filters.receiptNumber %>" />
            <input type="hidden" name="fDate" value="<%= filters.date %>" />
            <input type="hidden" name="fPaidBy" value="<%= filters.paidBy %>" />
            <input type="hidden" name="fPurpose" value="<%= filters.purpose %>" />
            <input type="hidden" name="fAmount" value="<%= filters.amount %>" />
        </form>

        <script>
            (() => {
                const LANGUAGE_STORAGE_KEY = "preferredLanguage";
                const currentLang = "<%= lang %>";
                const initialErrorMessage = <%- JSON.stringify(error || "") %>;
                const fallbackErrorMessage = <%- JSON.stringify(labels.unexpectedError) %>;
                const CLIENT_ERROR_PREFIX = "[CLIENT]";
                const SERVER_ERROR_PREFIX = "[SERVER]";
                const errorModalElement = document.getElementById("errorModal");
                const errorModalMessageElement = document.getElementById("errorModalMessage");
                const errorModal = errorModalElement ? new bootstrap.Modal(errorModalElement) : null;
                const deleteConfirmModalElement = document.getElementById("deleteConfirmModal");
                const deleteConfirmModal = deleteConfirmModalElement ? new bootstrap.Modal(deleteConfirmModalElement) : null;
                const replaceReceiptConfirmModalElement = document.getElementById("replaceReceiptConfirmModal");
                const replaceReceiptConfirmModal = replaceReceiptConfirmModalElement ? new bootstrap.Modal(replaceReceiptConfirmModalElement) : null;
                const settingsModalElement = document.getElementById("settingsModal");
                const settingsModal = settingsModalElement ? new bootstrap.Modal(settingsModalElement) : null;
                const annualAlertModalElement = document.getElementById("annualAlertModal");
                const annualAlertModal = annualAlertModalElement ? new bootstrap.Modal(annualAlertModalElement) : null;
                const receiptPreviewModalElement = document.getElementById("receiptPreviewModal");
                const receiptPreviewModalBody = document.getElementById("receiptPreviewModalBody");
                const receiptPreviewOpenInNewTabButton = document.getElementById("receiptPreviewOpenInNewTabButton");
                const receiptPreviewDownloadButton = document.getElementById("receiptPreviewDownloadButton");
                const receiptPreviewModal = receiptPreviewModalElement ? new bootstrap.Modal(receiptPreviewModalElement) : null;
                const openSettingsModalButton = document.getElementById("openSettingsModalButton");
                const backupModalElement = document.getElementById("backupModal");
                const backupModal = backupModalElement ? new bootstrap.Modal(backupModalElement) : null;
                const openBackupModalButton = document.getElementById("openBackupModalButton");
                const backupNowButton = document.getElementById("backupNowButton");
                const backupStatus = document.getElementById("backupStatus");
                const backupResults = document.getElementById("backupResults");
                const backupAuthSection = document.getElementById("backupAuthSection");
                const backupConnectedSection = document.getElementById("backupConnectedSection");
                const backupDisconnectButton = document.getElementById("backupDisconnectButton");
                const restoreFromDriveButton = document.getElementById("restoreFromDriveButton");
                const backupCredentialsSection = document.getElementById("backupCredentialsSection");
                const credentialsJsonInput = document.getElementById("credentialsJsonInput");
                const saveCredentialsButton = document.getElementById("saveCredentialsButton");
                const credentialsSaveStatus = document.getElementById("credentialsSaveStatus");
                const restoreInfoSection = document.getElementById("restoreInfoSection");
                const restoreBackupList = document.getElementById("restoreBackupList");
                const restoreSelectedName = document.getElementById("restoreSelectedName");
                const restoreConfirmSection = document.getElementById("restoreConfirmSection");
                const restoreConfirmButton = document.getElementById("restoreConfirmButton");
                const restoreCancelButton = document.getElementById("restoreCancelButton");
                let selectedRestoreFileId = "";
                const deleteTransactionForm = document.getElementById("deleteTransactionForm");
                const confirmDeleteButton = document.getElementById("confirmDeleteButton");
                const confirmReplaceReceiptButton = document.getElementById("confirmReplaceReceiptButton");
                const shouldShowAnnualAlert = <%- JSON.stringify(Boolean(shouldShowAnnualAlert)) %>;
                const receiptDirectory = <%- JSON.stringify(receiptDirectory || []) %>;
                const requiredFieldMessage = <%- JSON.stringify(labels.requiredField) %>;
                const duplicateReceiptMessage = <%- JSON.stringify(labels.duplicateReceiptNumber) %>;
                const paymentReferenceRequiredMessage = <%- JSON.stringify(labels.paymentReferenceRequired) %>;
                const invalidAttachmentTypeMessage = <%- JSON.stringify(labels.invalidAttachmentType || "Only image and PDF files are allowed.") %>;
                const replaceReceiptConfirmMessage = <%- JSON.stringify(labels.replaceReceiptConfirm) %>;
                const receiptPreviewLoadingMessage = <%- JSON.stringify(labels.receiptPreviewLoading || "Loading receipt preview...") %>;
                const receiptPreviewUnavailableMessage = <%- JSON.stringify(labels.receiptPreviewUnavailable || "Preview is unavailable for this file type. Please download the receipt.") %>;
                let pendingDeleteTransactionId = "";
                let activeReceiptPreviewObjectUrl = "";
                let pendingReplaceReceiptForm = null;
                let pendingReplaceReceiptSubmitter = null;
                let backupAuthErrorMessage = "";

                function escapeHtml (value) {
                    return String(value || "")
                        .replace(/&/g, "&amp;")
                        .replace(/</g, "&lt;")
                        .replace(/>/g, "&gt;")
                        .replace(/\"/g, "&quot;")
                        .replace(/'/g, "&#39;");
                }

                function renderBackupAuthErrorMessage () {
                    if (!backupAuthErrorMessage) {
                        return;
                    }

                    backupStatus.innerHTML = `<div class="alert alert-danger mb-0"><strong>✗ Error:</strong> ${escapeHtml(backupAuthErrorMessage)}</div>`;
                }

                function setBackupNowButtonVariant (isSecondary) {
                    if (!backupNowButton) {
                        return;
                    }

                    backupNowButton.classList.toggle("btn-secondary", isSecondary);
                    backupNowButton.classList.toggle("btn-primary", !isSecondary);
                }

                async function refreshBackupAuthState () {
                    let credentialsValid = true;
                    let showCredentialsInput = false;

                    try {
                        const credentialsCheckRes = await fetch("/admin/backup/credentials-status");
                        const credentialsCheckData = await credentialsCheckRes.json();
                        credentialsValid = Boolean(credentialsCheckData.credentialsValid);
                    } catch {
                        credentialsValid = false;
                    }

                    showCredentialsInput = !credentialsValid;

                    try {
                        const res = await fetch("/admin/backup/status");
                        const data = await res.json();
                        const authorized = data.configured && data.authorized;
                        let hasBackups = false;

                        if (authorized) {
                            try {
                                const backupsRes = await fetch("/admin/restore/backups");
                                const backupsData = await backupsRes.json();
                                hasBackups = Boolean(backupsData.success && Array.isArray(backupsData.files) && backupsData.files.length > 0);
                            } catch {
                                hasBackups = false;
                            }
                        }

                        backupAuthSection.classList.toggle("d-none", authorized || showCredentialsInput);
                        backupCredentialsSection.classList.toggle("d-none", !showCredentialsInput);
                        backupConnectedSection.classList.toggle("d-none", !authorized);
                        backupNowButton.classList.toggle("d-none", !authorized);
                        backupDisconnectButton.classList.toggle("d-none", !authorized);
                        restoreFromDriveButton.classList.toggle("d-none", !authorized || !hasBackups);
                        restoreInfoSection.classList.add("d-none");
                        setBackupNowButtonVariant(false);
                        if (backupAuthErrorMessage) {
                            renderBackupAuthErrorMessage();
                        }
                    } catch {
                        backupAuthSection.classList.toggle("d-none", showCredentialsInput);
                        backupCredentialsSection.classList.toggle("d-none", !showCredentialsInput);
                        backupConnectedSection.classList.add("d-none");
                        backupNowButton.classList.add("d-none");
                        backupDisconnectButton.classList.add("d-none");
                        restoreFromDriveButton.classList.add("d-none");
                        restoreInfoSection.classList.add("d-none");
                        setBackupNowButtonVariant(false);
                        if (backupAuthErrorMessage) {
                            renderBackupAuthErrorMessage();
                        }
                    }
                }

                async function loadBackupList () {
                    try {
                        setBackupNowButtonVariant(true);
                        restoreBackupList.innerHTML = '<div class="text-muted small">Loading backups...</div>';
                        restoreInfoSection.classList.remove("d-none");
                        const res = await fetch("/admin/restore/backups");
                        const data = await res.json();
                        restoreBackupList.innerHTML = "";
                        selectedRestoreFileId = "";
                        const restoreSelectedButton = document.getElementById("restoreSelectedButton");
                        if (!data.success || !data.files || !data.files.length) {
                            restoreBackupList.innerHTML = `<div class="text-muted small">${<%- JSON.stringify(labels.restoreNoBackups || "No backups found on Google Drive.") %>}</div>`;
                            if (restoreSelectedButton) restoreSelectedButton.classList.add("d-none");
                            return;
                        }
                        data.files.forEach((f, index) => {
                            const dateStr = f.modifiedTime ? new Date(f.modifiedTime).toLocaleString() : "";
                            const sizeStr = f.size ? `${(Number(f.size) / 1024 / 1024).toFixed(2)} MB` : "";
                            const label = document.createElement("label");
                            label.className = "d-flex align-items-start gap-2 border rounded p-2 bg-light cursor-pointer";
                            label.style.cursor = "pointer";
                            const radio = document.createElement("input");
                            radio.type = "radio";
                            radio.name = "restoreBackup";
                            radio.value = f.id;
                            radio.className = "form-check-input mt-0 flex-shrink-0";
                            if (index === 0) {
                                radio.checked = true;
                                selectedRestoreFileId = f.id;
                            }
                            radio.addEventListener("change", () => {
                                selectedRestoreFileId = f.id;
                            });
                            const text = document.createElement("span");
                            text.className = "small";
                            text.innerHTML = `<span class="fw-semibold">${f.name}</span>${dateStr ? `<br><span class="text-muted">${dateStr}</span>` : ""}${sizeStr ? ` <span class="text-muted">(${sizeStr})</span>` : ""}`;
                            label.appendChild(radio);
                            label.appendChild(text);
                            restoreBackupList.appendChild(label);
                        });
                        if (restoreSelectedButton) restoreSelectedButton.classList.remove("d-none");
                    } catch {
                        setBackupNowButtonVariant(false);
                        restoreInfoSection.classList.add("d-none");
                    }
                }

                function isAllowedAttachmentFileType (file) {
                    try {
                        if (!file) {
                            return true;
                        }

                        const mimeType = String(file.type || "").toLowerCase();
                        if (mimeType.startsWith("image/") || mimeType === "application/pdf") {
                            return true;
                        }

                        const fileName = String(file.name || "").toLowerCase();
                        return /\.(jpg|jpeg|png|gif|webp|bmp|svg|tif|tiff|heic|heif|avif|pdf)$/i.test(fileName);
                    } catch (error) {
                        throw withFunctionError("isAllowedAttachmentFileType", error);
                    }
                }

                function normalizeReceiptNumberValue (value) {
                    try {
                        return String(value || "").trim().toLowerCase();
                    } catch (error) {
                        throw withFunctionError("normalizeReceiptNumberValue", error);
                    }
                }

                function isDuplicateReceipt (value, excludeTransactionId = "", originalReceipt = "") {
                    try {
                        const normalized = normalizeReceiptNumberValue(value);
                        if (!normalized) {
                            return false;
                        }

                        if (normalized === normalizeReceiptNumberValue(originalReceipt)) {
                            return false;
                        }

                        return receiptDirectory.some((entry) => {
                            if (!entry || typeof entry !== "object") {
                                return false;
                            }

                            if (excludeTransactionId && String(entry.id || "") === String(excludeTransactionId)) {
                                return false;
                            }

                            return normalizeReceiptNumberValue(entry.receiptNumber) === normalized;
                        });
                    } catch (error) {
                        throw withFunctionError("isDuplicateReceipt", error);
                    }
                }

                function shouldRequirePaymentReference (paymentMethod, status = "") {
                    try {
                        const normalizedStatus = String(status || "").trim().toLowerCase();
                        if (normalizedStatus === "pending") {
                            return false;
                        }

                        return paymentMethod === "credit_card" || paymentMethod === "bank_transfer" || paymentMethod === "cheque";
                    } catch (error) {
                        throw withFunctionError("shouldRequirePaymentReference", error);
                    }
                }

                function normalizePaidByAutocompleteSelection (rawValue) {
                    try {
                        const normalizedInput = String(rawValue || "").trim();
                        const match = /^(.*?)(?:\s*\(CUST-\d+\))$/i.exec(normalizedInput);
                        if (!match) {
                            return normalizedInput;
                        }

                        return String(match[1] || "").trim();
                    } catch (error) {
                        throw withFunctionError("normalizePaidByAutocompleteSelection", error);
                    }
                }

                function shouldEnableAutocomplete (value) {
                    try {
                        return String(value || "").trim().length >= 2;
                    } catch (error) {
                        throw withFunctionError("shouldEnableAutocomplete", error);
                    }
                }

                function isImageAttachmentPath (filePath) {
                    try {
                        return /\.(png|jpe?g|gif|webp|bmp|svg|avif|heic|heif|tiff?)$/i.test(String(filePath || "").split("?")[0]);
                    } catch (error) {
                        throw withFunctionError("isImageAttachmentPath", error);
                    }
                }

                function isPdfAttachmentPath (filePath) {
                    try {
                        return /\.pdf$/i.test(String(filePath || "").split("?")[0]);
                    } catch (error) {
                        throw withFunctionError("isPdfAttachmentPath", error);
                    }
                }

                function isImageMimeType (mimeType) {
                    try {
                        return /^image\//i.test(String(mimeType || ""));
                    } catch (error) {
                        throw withFunctionError("isImageMimeType", error);
                    }
                }

                function isPdfMimeType (mimeType) {
                    try {
                        return /application\/pdf/i.test(String(mimeType || ""));
                    } catch (error) {
                        throw withFunctionError("isPdfMimeType", error);
                    }
                }

                function revokeActiveReceiptPreviewObjectUrl () {
                    try {
                        if (activeReceiptPreviewObjectUrl) {
                            URL.revokeObjectURL(activeReceiptPreviewObjectUrl);
                            activeReceiptPreviewObjectUrl = "";
                        }
                    } catch (error) {
                        throw withFunctionError("revokeActiveReceiptPreviewObjectUrl", error);
                    }
                }

                function setReceiptPreviewUnavailableState () {
                    try {
                        if (!receiptPreviewModalBody) {
                            return;
                        }

                        receiptPreviewModalBody.innerHTML = "";
                        const notice = document.createElement("div");
                        notice.className = "alert alert-secondary mb-0";
                        notice.textContent = receiptPreviewUnavailableMessage;
                        receiptPreviewModalBody.appendChild(notice);
                    } catch (error) {
                        throw withFunctionError("setReceiptPreviewUnavailableState", error);
                    }
                }

                function detectPreviewKindFromBytes (bytes) {
                    try {
                        if (!bytes || bytes.length < 4) {
                            return "unknown";
                        }

                        const isJpeg = bytes[0] === 0xFF && bytes[1] === 0xD8 && bytes[2] === 0xFF;
                        const isPng = bytes.length >= 8 &&
                            bytes[0] === 0x89 && bytes[1] === 0x50 && bytes[2] === 0x4E && bytes[3] === 0x47 &&
                            bytes[4] === 0x0D && bytes[5] === 0x0A && bytes[6] === 0x1A && bytes[7] === 0x0A;
                        const isGif = bytes[0] === 0x47 && bytes[1] === 0x49 && bytes[2] === 0x46 && bytes[3] === 0x38;
                        const isBmp = bytes[0] === 0x42 && bytes[1] === 0x4D;
                        const isPdf = bytes[0] === 0x25 && bytes[1] === 0x50 && bytes[2] === 0x44 && bytes[3] === 0x46;
                        const isWebp = bytes.length >= 12 &&
                            bytes[0] === 0x52 && bytes[1] === 0x49 && bytes[2] === 0x46 && bytes[3] === 0x46 &&
                            bytes[8] === 0x57 && bytes[9] === 0x45 && bytes[10] === 0x42 && bytes[11] === 0x50;

                        if (isPdf) {
                            return "pdf";
                        }

                        if (isJpeg || isPng || isGif || isBmp || isWebp) {
                            return "image";
                        }

                        return "unknown";
                    } catch (error) {
                        throw withFunctionError("detectPreviewKindFromBytes", error);
                    }
                }

                function detectPreviewKindFromBlob (blob, filePath) {
                    try {
                        const mimeType = String(blob?.type || "").toLowerCase();
                        if (isImageMimeType(mimeType) || isImageAttachmentPath(filePath)) {
                            return Promise.resolve("image");
                        }

                        if (isPdfMimeType(mimeType) || isPdfAttachmentPath(filePath)) {
                            return Promise.resolve("pdf");
                        }

                        return blob.arrayBuffer()
                            .then((buffer) => {
                                const bytes = new Uint8Array(buffer.slice(0, 16));
                                return detectPreviewKindFromBytes(bytes);
                            })
                            .catch(() => "unknown");
                    } catch (error) {
                        throw withFunctionError("detectPreviewKindFromBlob", error);
                    }
                }

                function openReceiptPreviewModal (filePath) {
                    try {
                        const normalizedPath = String(filePath || "").trim();
                        if (!normalizedPath || !receiptPreviewModal || !receiptPreviewModalBody || !receiptPreviewDownloadButton || !receiptPreviewOpenInNewTabButton) {
                            return;
                        }

                        revokeActiveReceiptPreviewObjectUrl();
                        receiptPreviewModalBody.innerHTML = "";
                        receiptPreviewDownloadButton.href = normalizedPath;
                        receiptPreviewOpenInNewTabButton.href = normalizedPath;
                        receiptPreviewModalBody.innerHTML = `<p class="text-secondary mb-0">${receiptPreviewLoadingMessage}</p>`;
                        receiptPreviewModal.show();

                        fetch(normalizedPath, {
                                credentials: "same-origin"
                            })
                            .then((response) => {
                                if (!response.ok) {
                                    throw new Error(`Failed to fetch receipt (${response.status})`);
                                }

                                return response.blob();
                            })
                            .then((blob) => detectPreviewKindFromBlob(blob, normalizedPath)
                                .then((previewKind) => ({
                                    blob,
                                    previewKind
                                })))
                            .then(({
                                blob,
                                previewKind
                            }) => {
                                revokeActiveReceiptPreviewObjectUrl();
                                activeReceiptPreviewObjectUrl = URL.createObjectURL(blob);
                                receiptPreviewModalBody.innerHTML = "";

                                if (previewKind === "image") {
                                    const image = document.createElement("img");
                                    image.src = activeReceiptPreviewObjectUrl;
                                    image.alt = "Receipt preview";
                                    image.className = "img-fluid rounded border";
                                    image.addEventListener("error", safeHandler(() => {
                                        setReceiptPreviewUnavailableState();
                                    }));
                                    receiptPreviewModalBody.appendChild(image);
                                    return;
                                }

                                if (previewKind === "pdf") {
                                    const frame = document.createElement("iframe");
                                    frame.src = activeReceiptPreviewObjectUrl;
                                    frame.title = "Receipt preview";
                                    frame.style.width = "100%";
                                    frame.style.minHeight = "70vh";
                                    frame.style.border = "1px solid #d9e2f2";
                                    frame.style.borderRadius = "0.75rem";
                                    receiptPreviewModalBody.appendChild(frame);
                                    return;
                                }

                                setReceiptPreviewUnavailableState();
                            })
                            .catch((error) => {
                                console.error(withFunctionError("openReceiptPreviewModal.fetch", error));
                                setReceiptPreviewUnavailableState();
                            });
                    } catch (error) {
                        throw withFunctionError("openReceiptPreviewModal", error);
                    }
                }

                function initializeCustomerAndPaymentFields (form) {
                    try {
                        if (!form) {
                            return;
                        }

                        const paymentMethodSelect = form.querySelector('[name="payment_method"]');
                        const statusSelect = form.querySelector('[name="status"]');
                        const paymentReferenceWrapper = form.querySelector("[data-payment-reference-wrapper]");
                        const paymentReferenceInput = form.querySelector('[name="payment_reference"]');
                        const paidByInput = form.querySelector('[name="paidBy"]');
                        const purposeInput = form.querySelector('[name="purpose"]');

                        function updatePaymentReferenceState () {
                            try {
                                if (!paymentMethodSelect || !paymentReferenceInput) {
                                    return;
                                }

                                const currentStatus = statusSelect ? statusSelect.value : "";
                                const mustHaveReference = shouldRequirePaymentReference(paymentMethodSelect.value, currentStatus);
                                const shouldShowReferenceField = String(paymentMethodSelect.value || "").trim().toLowerCase() !== "cash";
                                paymentReferenceInput.required = mustHaveReference;

                                // If payment method is cash, clear the payment reference field
                                if (String(paymentMethodSelect.value || "").trim().toLowerCase() === "cash") {
                                    paymentReferenceInput.value = "";
                                }

                                if (paymentReferenceWrapper) {
                                    paymentReferenceWrapper.classList.toggle("d-none", !shouldShowReferenceField);
                                }

                                if (!mustHaveReference) {
                                    paymentReferenceInput.setCustomValidity("");
                                }
                            } catch (error) {
                                throw withFunctionError("updatePaymentReferenceState", error);
                            }
                        }

                        if (paymentMethodSelect && paymentReferenceInput) {
                            paymentMethodSelect.addEventListener("change", safeHandler(updatePaymentReferenceState));
                            if (statusSelect) {
                                statusSelect.addEventListener("change", safeHandler(updatePaymentReferenceState));
                            }
                            updatePaymentReferenceState();
                        }

                        if (paidByInput) {
                            const knownCustomersListId = paidByInput.getAttribute("list") || "knownCustomersList";

                            const normalizePaidByField = () => {
                                paidByInput.value = normalizePaidByAutocompleteSelection(paidByInput.value);
                            };

                            const updatePaidByAutocompleteState = () => {
                                if (shouldEnableAutocomplete(paidByInput.value)) {
                                    paidByInput.setAttribute("list", knownCustomersListId);
                                } else {
                                    paidByInput.removeAttribute("list");
                                }
                            };

                            paidByInput.addEventListener("change", safeHandler(normalizePaidByField));
                            paidByInput.addEventListener("blur", safeHandler(normalizePaidByField));
                            paidByInput.addEventListener("input", safeHandler(updatePaidByAutocompleteState));
                            paidByInput.addEventListener("focus", safeHandler(updatePaidByAutocompleteState));
                            normalizePaidByField();
                            updatePaidByAutocompleteState();
                        }

                        if (purposeInput) {
                            const knownPurposesListId = purposeInput.getAttribute("list") || "knownPurposesList";

                            const updatePurposeAutocompleteState = () => {
                                if (shouldEnableAutocomplete(purposeInput.value)) {
                                    purposeInput.setAttribute("list", knownPurposesListId);
                                } else {
                                    purposeInput.removeAttribute("list");
                                }
                            };

                            purposeInput.addEventListener("input", safeHandler(updatePurposeAutocompleteState));
                            purposeInput.addEventListener("focus", safeHandler(updatePurposeAutocompleteState));
                            updatePurposeAutocompleteState();
                        }
                    } catch (error) {
                        throw withFunctionError("initializeCustomerAndPaymentFields", error);
                    }
                }

                function updateReceiptFeedback (input, message) {
                    try {
                        if (!input) {
                            return;
                        }

                        const wrapper = input.closest("div");
                        const feedback = wrapper ? wrapper.querySelector(".invalid-feedback") : null;
                        if (!feedback) {
                            return;
                        }

                        feedback.textContent = message || requiredFieldMessage;
                    } catch (error) {
                        throw withFunctionError("updateReceiptFeedback", error);
                    }
                }

                function withFunctionError (functionName, error) {
                    const message = error instanceof Error ? error.message : String(error);
                    const contextualError = new Error(`[${functionName}] ${message}`);
                    contextualError.cause = error;
                    return contextualError;
                }

                function showErrorModal (message) {
                    try {
                        if (!errorModal || !errorModalMessageElement) {
                            return;
                        }

                        errorModalMessageElement.textContent = message || fallbackErrorMessage;
                        errorModal.show();
                    } catch (modalError) {
                        console.error(modalError);
                    }
                }

                function toClientErrorMessage (message) {
                    try {
                        const normalizedMessage = String(message || fallbackErrorMessage);
                        if (normalizedMessage.startsWith(CLIENT_ERROR_PREFIX) || normalizedMessage.startsWith(SERVER_ERROR_PREFIX)) {
                            return normalizedMessage;
                        }

                        return `${CLIENT_ERROR_PREFIX} ${normalizedMessage}`;
                    } catch (error) {
                        return `${CLIENT_ERROR_PREFIX} ${fallbackErrorMessage}`;
                    }
                }

                function safeRun (fn) {
                    try {
                        fn();
                    } catch (runtimeError) {
                        console.error(runtimeError);
                        showErrorModal(toClientErrorMessage(runtimeError.message || fallbackErrorMessage));
                    }
                }

                function safeHandler (handler) {
                    return (...args) => {
                        try {
                            handler(...args);
                        } catch (runtimeError) {
                            console.error(runtimeError);
                            showErrorModal(toClientErrorMessage(runtimeError.message || fallbackErrorMessage));
                        }
                    };
                }

                window.addEventListener("error", (event) => {
                    const message = event.error?.message || event.message || fallbackErrorMessage;
                    showErrorModal(toClientErrorMessage(message));
                });

                window.addEventListener("unhandledrejection", (event) => {
                    const reason = event.reason;
                    const message = reason?.message || String(reason || fallbackErrorMessage);
                    showErrorModal(toClientErrorMessage(message));
                });

                safeRun(() => {
                    fetch("/admin/uploads/cleanup-if-empty", {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json"
                        },
                    }).catch(() => {
                        // Ignore cleanup request failures to avoid interrupting the page UX.
                    });
                });

                safeRun(() => {
                    function isSupportedLanguage (value) {
                        try {
                            return value === "en" || value === "he";
                        } catch (error) {
                            throw withFunctionError("isSupportedLanguage", error);
                        }
                    }

                    function setLanguageCookie (value) {
                        try {
                            document.cookie = `lang=${encodeURIComponent(value)}; path=/; max-age=31536000; samesite=lax`;
                        } catch (error) {
                            throw withFunctionError("setLanguageCookie", error);
                        }
                    }

                    function setLanguageAndReload (value) {
                        try {
                            if (!isSupportedLanguage(value)) {
                                return;
                            }

                            localStorage.setItem(LANGUAGE_STORAGE_KEY, value);
                            setLanguageCookie(value);
                            window.location.href = `${window.location.pathname}${window.location.hash}`;
                        } catch (error) {
                            throw withFunctionError("setLanguageAndReload", error);
                        }
                    }

                    const storedLang = localStorage.getItem(LANGUAGE_STORAGE_KEY);
                    if (isSupportedLanguage(storedLang) && storedLang !== currentLang) {
                        setLanguageCookie(storedLang);
                        window.location.href = `${window.location.pathname}${window.location.hash}`;
                        return;
                    }

                    if (!isSupportedLanguage(storedLang)) {
                        localStorage.setItem(LANGUAGE_STORAGE_KEY, currentLang);
                        setLanguageCookie(currentLang);
                    }

                    document.querySelectorAll("[data-lang-switch]").forEach((element) => {
                        element.addEventListener("click", safeHandler(() => {
